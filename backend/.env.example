PDF_COMPARE_APP_NAME=PDF Compare API
PDF_COMPARE_APP_ENV=dev
PDF_COMPARE_API_PREFIX=/api

# 本機開發路徑（Docker 部署時由 docker-compose.yml 的 environment 覆蓋）
PDF_COMPARE_STORAGE_ROOT=/path/to/pdf-compare/var/compare
PDF_COMPARE_FRONTEND_DIR=/path/to/pdf-compare/frontend
PDF_COMPARE_JOBS_DIR_NAME=jobs
PDF_COMPARE_MAX_PDF_MB=50
PDF_COMPARE_MAX_PAGES=200
PDF_COMPARE_RETENTION_HOURS=24

# 本機開發用 Redis（Docker 部署時由 docker-compose.yml 覆蓋為 redis://redis:6379/x）
PDF_COMPARE_REDIS_URL=redis://localhost:6379/0
PDF_COMPARE_CELERY_BROKER_URL=redis://localhost:6379/0
PDF_COMPARE_CELERY_RESULT_BACKEND=redis://localhost:6379/1

PDF_COMPARE_RENDER_DPI=240
PDF_COMPARE_DIFF_THRESHOLD=25
PDF_COMPARE_DIFF_MIN_AREA=40
PDF_COMPARE_MASK_ALPHA=220
PDF_COMPARE_SMART_THUMB_SIZE=32
PDF_COMPARE_SMART_GAP_PENALTY=0.35
PDF_COMPARE_SMART_MATCH_BIAS=0.25
PDF_COMPARE_SMART_MIN_SIMILARITY=0.45
PDF_COMPARE_SMART_TEXT_WEIGHT=0.3
PDF_COMPARE_SMART_IMAGE_WEIGHT=0.7
PDF_COMPARE_COMPARE_TASK_SOFT_TIMEOUT_SEC=1200
PDF_COMPARE_COMPARE_TASK_HARD_TIMEOUT_SEC=1500

# LLM 設定（請依實際環境修改）
PDF_COMPARE_LLM_BASE_URL=http://your-llm-host:8001
PDF_COMPARE_LLM_MODEL=gemma-4:31B
PDF_COMPARE_LLM_MAX_TOKENS=16384
PDF_COMPARE_LLM_TEMPERATURE=0.2
PDF_COMPARE_LLM_ANALYZE_DPI=72
PDF_COMPARE_LLM_TIMEOUT_SEC=600
